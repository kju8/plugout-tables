---
import type { CollectionEntry } from "astro:content";

interface Props {
  multimode: boolean;
  list: CollectionEntry<"charts">[];
}
const { multimode = false, list } = Astro.props;

const bmTotal = (notes: number) => (Math.floor(14933 / notes) * notes) / 55;
const iidxTotal = (notes: number) =>
  Math.max(260, (7.605 * notes) / (0.01 * notes + 6.5));
---

<div id="chart_table" class={multimode ? "multimode" : ""}>
  <div></div>
  <div>IR</div>
  <div>SCORE</div>
  <div></div>
  <div>LEVEL</div>
  <div>GENRE</div>
  <div>TITLE</div>
  <div>ARTIST</div>
  <div>JUDGE</div>
  <div>BPM</div>
  <div>LENGTH</div>
  <div>NOTES</div>
  <div>
    譜面密度<br /><small>(NOTES/SEC.)</small>
  </div>
  <div>TOTAL</div>
  <div>
    回復量<br /><small>(T/N)</small>
  </div>
  {
    list.map((v) => (
      <>
        <div>
          {v.data.package.series}
          {(v.data.package.series === "plugout4" ||
            v.data.package.series === "plugout5") && (
            <>
              <br />
              <small>{v.data.package.phase}</small>
            </>
          )}
        </div>
        <div>
          <a
            href={`http://www.dream-pro.info/~lavalse/LR2IR/search.cgi?mode=ranking&bmsmd5=${v.data.md5}`}
          >
            <img src="/LR2.png" class="inline size-[1lh]" />
          </a>
          <a
            href={`https://mocha-repository.info/song.php?sha256=${v.data.sha256}`}
          >
            ☕
          </a>
          <a
            href={`https://www.gaftalk.com/minir/#/viewer/song/${v.data.sha256}/0`}
          >
            <img src="/MinIR.png" class="inline size-[1lh]" />
          </a>
        </div>
        <div>
          <a
            href={`https://bms-score-viewer.pages.dev/view?md5=${v.data.md5}`}
            target="_blank"
          >
            📈
          </a>
        </div>
        <div data-player={v.data.player}>
          {v.data.player === "single" ? "SP" : "DP"}
        </div>
        <div data-level={v.data.level}>☆{v.data.level}</div>
        <div>{v.data.genre}</div>
        <div set:html={v.data.title.replace("(", "<br />(")} />
        <div>{v.data.artist}</div>
        <div data-judge={v.data.judge}>
          {v.data.judge?.toUpperCase() ?? "―――"}
        </div>
        <div>
          {Array.isArray(v.data.bpm)
            ? `${v.data.bpm[0]}～${v.data.bpm[1]}`
            : v.data.bpm}
        </div>
        <div>{v.data.length.toFixed(2)} s</div>
        <div data-notes={v.data.notes}>{v.data.notes}</div>
        <div data-dense={v.data.notes / v.data.length}>
          {(v.data.notes / v.data.length).toFixed(3)}
        </div>
        <div
          data-iidx={
            (v.data.total ?? iidxTotal(v.data.notes)) / iidxTotal(v.data.notes)
          }
        >
          {v.data.total !== undefined ? (
            <>
              {v.data.total.toFixed(2)}
              <small class="tooltip">{`(FINAL比: ${((v.data.total * 100) / bmTotal(v.data.notes)).toFixed(2)}%, IIDX比: ${((v.data.total * 100) / iidxTotal(v.data.notes)).toFixed(2)}%)`}</small>
            </>
          ) : (
            <>
              ({iidxTotal(v.data.notes).toFixed(2)})
              <small class="tooltip">{`(FINAL比: ${((iidxTotal(v.data.notes) * 100) / bmTotal(v.data.notes)).toFixed(2)}%, IIDX比: 100.00%)`}</small>
            </>
          )}
        </div>
        <div data-tn={(v.data.total ?? iidxTotal(v.data.notes)) / v.data.notes}>
          {v.data.total !== undefined
            ? (v.data.total / v.data.notes).toFixed(3)
            : `(${(iidxTotal(v.data.notes) / v.data.notes).toFixed(3)})`}
        </div>
      </>
    ))
  }
</div>

<style>
  @import "tailwindcss";

  #chart_table {
    @apply w-full grid border-t border-l border-mist-800/40;

    font-size: 0.7rem;

    grid-template-columns:
      max-content max-content min-content min-content min-content
      max-content max-content max-content
      min-content max-content max-content min-content min-content min-content min-content;
  }

  #chart_table:not(.multimode) {
    grid-template-columns:
      max-content min-content min-content min-content
      max-content max-content max-content
      min-content max-content max-content min-content min-content min-content min-content;
  }

  #chart_table > div {
    @apply border-b border-r border-mist-800/40;

    position: relative;
    padding: 0.2rem 0.5rem;
    text-align: center;
  }

  #chart_table > div[data-player="single"] {
    @apply bg-blue-400/30;
  }

  #chart_table > div[data-player="double"] {
    @apply bg-red-400/30;
  }

  #chart_table > div[data-level] {
    --level: attr(data-level type(<number>));
    --level-low: min(max(calc(var(--level) - 5), 0), 1);
    --level-hi: min(max(calc(var(--level) - 9), 0), 1);

    --color-low: color-mix(
      in hsl,
      var(--color-teal-400),
      var(--color-yellow-400) calc(25% * calc(var(--level) - 1))
    );
    --color-mid: color-mix(
      in hsl,
      var(--color-yellow-400),
      var(--color-red-600) calc(25% * calc(var(--level) - 5))
    );
    --color-hi: color-mix(
      in hsl,
      var(--color-red-600),
      var(--color-violet-500) calc(25% * calc(var(--level) - 9))
    );

    --diffcolor: color-mix(
      in hsl,
      color-mix(
        in hsl,
        var(--color-low),
        var(--color-mid) calc(100% * var(--level-low))
      ),
      var(--color-hi) calc(100% * var(--level-hi))
    );

    background-color: color-mix(in srgb, var(--diffcolor), transparent 75%);
  }

  #chart_table > div[data-judge="easy"] {
    @apply bg-green-400/25;
  }

  #chart_table > div[data-judge="normal"] {
    @apply bg-yellow-400/25;
  }

  #chart_table > div[data-judge="hard"] {
    @apply bg-red-500/25;
  }

  #chart_table > div[data-judge="veryhard"] {
    @apply bg-purple-500/25;
  }

  #chart_table > div[data-notes] {
    --chart-notes: attr(data-notes type(<number>));

    --color-low: color-mix(
      in hsl,
      var(--color-green-400),
      var(--color-red-600) min(calc(100% * var(--chart-notes) / 999), 100%)
    );
    --color-hi: color-mix(
      in hsl,
      var(--color-red-600),
      var(--color-violet-500)
        min(
          calc(
            100% * calc(atan(calc(var(--chart-notes) / 999)) - 45deg) / 45deg
          ),
          100%
        )
    );

    --color-mixed: color-mix(
      in hsl,
      var(--color-low),
      var(--color-hi)
        calc(100% * max(min(calc(var(--chart-notes) - 999), 1), 0))
    );

    background-color: color-mix(in srgb, var(--color-mixed), transparent 75%);
  }

  #chart_table > div[data-dense] {
    --dense-rate: attr(data-dense type(<number>));

    background-color: color-mix(
      in srgb,
      color-mix(
        in hsl,
        var(--color-green-400),
        var(--color-red-600) min(calc(100% * var(--dense-rate) / 12), 100%)
      ),
      transparent 75%
    );
  }

  #chart_table > div[data-iidx] {
    --totalRate: attr(data-iidx type(<number>));

    --color-low: color-mix(
      in hsl,
      var(--color-red-600),
      var(--color-yellow-400)
        min(calc(100% * atan(var(--totalRate)) / 45deg), 100%)
    );
    --color-hi: color-mix(
      in hsl,
      var(--color-yellow-400),
      var(--color-green-500)
        min(calc(100% * calc(atan(var(--totalRate)) - 45deg) / 45deg), 100%)
    );

    --color-mixed: color-mix(
      in hsl,
      var(--color-low),
      var(--color-hi)
        calc(100% * min(calc(var(--totalRate) - mod(var(--totalRate), 1)), 1))
    );

    background-color: color-mix(in srgb, var(--color-mixed), transparent 75%);
  }

  #chart_table > div[data-tn] {
    --totalRate: attr(data-tn type(<number>));

    --color-total: color-mix(
      in hsl,
      var(--color-red-500),
      var(--color-green-500) calc(100% * atan(var(--totalRate)) / 90deg)
    );

    background-color: color-mix(in srgb, var(--color-total), transparent 75%);
  }

  #chart_table > div:nth-child(-n + 15) {
    font-size: 0.6rem;
    font-weight: bold;
    padding: 0.2rem 0.3rem;
  }

  #chart_table > div:nth-child(15n + 1) {
    font-size: 0.6rem;
    font-weight: bold;
  }

  #chart_table > div:nth-child(15n + 21),
  #chart_table > div:nth-child(15n + 22),
  #chart_table > div:nth-child(15n + 23) {
    font-family: "M PLUS 1p", sans-serif;
  }

  #chart_table > div:nth-child(15n + 7) {
    font-weight: bold;
  }

  #chart_table:not(.multimode) > div:nth-child(15n + 1) {
    display: none;
  }

  #chart_table > div > .tooltip {
    display: none;
    position: absolute;
    width: max-content;
    bottom: 0px;
    right: 0px;
    margin-right: -6em;
    padding: 0.1rem;
    background-color: rgba(255, 255, 255, 0.6);
    z-index: 2;
  }

  #chart_table > div:hover > .tooltip {
    display: block;
  }
</style>
