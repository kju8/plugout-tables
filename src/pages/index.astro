---
import { getCollection } from "astro:content";

import MainLayout from "../layouts/Main.astro";
import DifficultyTable from "../components/DifficultyTable.astro";
import { ChartSort } from "../lib/lib";

const Charts = ChartSort(await getCollection("charts"));
---

<MainLayout title="plugout Difficulty Table" data={"header.json"}>
  <DifficultyTable multimode={true} list={Charts} />
</MainLayout>
